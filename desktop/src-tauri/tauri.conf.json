{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fantasy Studio",
  "mainBinaryName": "FantasyStudio",
  "version": "0.1.0",
  "identifier": "ai.fantasylab.studio",
  "build": {
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Fantasy Studio",
        "width": 1440,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 720,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": ["msi", "nsis"],
    "icon": []
  }
}
