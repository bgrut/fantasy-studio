# Fantasy Studio backend — environment configuration template
# Copy to backend/.env and fill in your values. The .env file itself
# is gitignored; this template is committed.

# ── Sketchfab API token (optional but recommended) ─────────────────
# Used as a fallback asset source when the curated library doesn't have
# what your prompt asks for. Without it, fallback only uses Objaverse.
# Get a free token at https://sketchfab.com/settings/password
SKETCHFAB_API_TOKEN=

# ── Local LLM (Ollama / Gemma) ─────────────────────────────────────
# Director model for prompt → scene plan. Defaults to gemma3:12b on a
# locally-running Ollama instance. The deterministic fallback runs if
# Ollama is unreachable or the model isn't pulled.
FANTASY_LLM_MODEL=gemma3:12b
FANTASY_LLM_HOST=http://localhost:11434
FANTASY_LLM_TIMEOUT=30
FANTASY_LLM_ENABLED=true
