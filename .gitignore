# ───────────────────────────────────────────────────────────────────
# Fantasy Studio — public docs repo .gitignore
# Sibling repos (blender-studio-backend, blender-studio) ship their
# own .gitignore. This one mirrors common patterns so contributors
# who clone all three side-by-side don't accidentally stage junk.
# ───────────────────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
.env
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
.python-version

# ── Node / Frontend ───────────────────────────────────────────────
node_modules/
.next/
.vite/
dist/
.cache/
.parcel-cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Blender ───────────────────────────────────────────────────────
*.blend1
*.blend2
*.blend@
*.blend.lock

# ── IDEs / Editors ────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.history/

# ── OS artifacts ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# ── Project-specific (Fantasy Studio) ─────────────────────────────
# Render outputs and large per-render artifacts
outputs/
**/blender_render_*/
*.mp4

# Asset cache (heavy, regenerable)
assets/cache/
assets/_ingest_staging/
assets/thumbnails/*.tmp

# Backup files (project convention: *.bak_<tag>)
*.bak
*.bak_*

# Pipeline trace logs
pipeline_trace.log
**/pipeline_trace.log

# Library refresh / triage artifacts (regeneratable)
library_refresh_report.json
library_triage_report.json
vehicle_lod_audit.json
downloads_processed.json

# Heal logs
heal_library.log
triage_orient.log

# Worktrees + Claude sessions
.claude/
**/worktrees/

# Manifest snapshots (huge, regenerable)
**/manifests/manifest_*.json

# ── Secrets / credentials (paranoia) ──────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets/
credentials.json
service-account*.json
.aws/
.ssh/

# ── Test artifacts ────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
nosetests.xml
*.cover

# ── Misc ──────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
*.rej

# ── Allow exception ───────────────────────────────────────────────
# Keep the placeholder so the assets folder ships in the repo
!.github/assets/.gitkeep
