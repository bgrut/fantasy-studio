# Fantasy Studio frontend — environment configuration template
# Copy to frontend/.env.local and fill in your values. The
# .env.local file itself is gitignored; this template is committed.

# ── Blink SDK (optional) ───────────────────────────────────────────
# Frontend SDK used for analytics + project sync. Without these the
# app still runs but Blink-backed features (project library sync,
# share links) won't function. Get credentials from
# https://blink.new (free tier available).
VITE_BLINK_PROJECT_ID=
VITE_BLINK_PUBLISHABLE_KEY=
